# ─────────────────────────────────────────────────────
#  Agentic QA — Target Repository Config
#  Edit this file to change the repo being tested.
#  Then run:  python main.py
# ─────────────────────────────────────────────────────

# GitHub URL of the repository to test (required)
GITHUB_REPO_URL=https://github.com/Narmadha-M/agentic-qa

# Branch to clone and watch (optional — defaults to repo's default branch)
GITHUB_BRANCH=master

# How often to check for new commits in Scenario B watch mode (seconds)
POLL_INTERVAL=60
